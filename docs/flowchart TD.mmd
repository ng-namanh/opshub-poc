flowchart TD
    classDef primary fill:#e3f2fd,stroke:#1e88e5,stroke-width:2px;
    classDef secondary fill:#f3e5f5,stroke:#8e24aa,stroke-width:2px;
    classDef database fill:#e8f5e9,stroke:#43a047,stroke-width:2px;
    classDef export fill:#fff3e0,stroke:#fb8c00,stroke-width:2px;

    %% Phase 1: Client-Side Ingestion
    subgraph Phase 1: Client-Side Ingestion [1, 2]
        A[Blank .docx File Upload]:::primary --> B(JSZip / pizzip: Extract ArrayBuffer)
        B --> C{mammoth.js}:::primary
        C -- Converts OOXML to --> D[Clean Semantic HTML String]
    end

    %% Phase 2: AST Traversal & React Interaction
    subgraph Phase 2: Translation & Interaction [3-5]
        D --> E{html-react-parser}:::secondary
        E -- Intercepts '......' via Regex --> F[React Virtual DOM]
        F -- Injects --> G[Interactive React Input Components]:::secondary
        G <-->|onChange events| H[(Central State Dictionary)]
        H <-->|useIndexedDBState| I[(IndexedDB: Local Backup)]:::database
    end

    %% Phase 3: Export and Decoupled Database Persistence
    subgraph Phase 3: Export & Decoupled Storage [6-8]
        H -- Local Export Process --> J{docxtemplater}:::export
        A -. Provides Original Binary Template .-> J
        J -- Injects React State --> K[Populated .docx Download]:::export
        
        H -- Server Persistence --> L[Backend REST/GraphQL API]
        L --> M[(Cloud Storage e.g. AWS S3: Base Template)]:::database
        L --> N[(PostgreSQL Database: JSONB form_data Payload)]:::database
    end

    %% Phase 4: Server-to-Client Rehydration
    subgraph Phase 4: Workflow Rehydration [9]
        O[User Requests Completed Document] --> P[API Retrieves S3 URL + JSONB Payload]
        P --> Q[Vite / React Client]
        Q -- 1. Downloads Base Template --> C
        Q -- 2. Natively Hydrates State --> H
    end